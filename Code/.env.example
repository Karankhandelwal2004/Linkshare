MONGODB_URL="mongodb+srv://<user>:<password>@cluster0.example.mongodb.net/<dbname>?retryWrites=true&w=majority"
SECRET_KEY=replace-with-a-secure-random-string
ADMIN_PASSWORD=change-me

# Do NOT commit your production credentials. Use platform environment variables or a secrets manager.
# Copy this file to .env and fill in your values
# NEVER commit .env to git — it contains secrets

# MongoDB Atlas connection string (mongodb+srv://...)
MONGODB_URL=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/

# Random secret for signing session cookies — use a long random string
SECRET_KEY=change-this-to-a-long-random-string

# Admin panel password — set something strong, never share it
ADMIN_PASSWORD=change-this-to-a-strong-password

# Port (set automatically by Railway/Render/Fly — override for local dev)
# PORT=3000
